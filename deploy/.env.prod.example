# ---------------------------------------------------------------
# 生产环境变量模板 · 复制为 .env.prod 后填入真实值
# 真实的 .env.prod 不要提交到 git（.gitignore 已排除）
# ---------------------------------------------------------------

# PostgreSQL 凭据（**必须**修改为强密码，不能沿用示例）
POSTGRES_DB=webtutor
POSTGRES_USER=dev
POSTGRES_PASSWORD=please-change-me-to-strong-password

# 镜像标签
# - 首次部署或运维手工操作：用 "latest"
# - 从 CI 部署：GitHub Actions 会覆盖为具体 sha（如 sha-a1b2c3d）
# - 回滚：改成上一版本的 sha 即可
IMAGE_TAG=latest

# 镜像仓库前缀（末尾要带 /）
# 使用腾讯云 TCR 企业版：<实例登录地址>/<命名空间>/
IMAGE_REGISTRY=imur-yuanpei.tencentcloudcr.com/mur-yuanpei/
