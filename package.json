{
  "name": "web-dev-tutorial",
  "private": true,
  "version": "0.1.0",
  "description": "面向大一学生的 Web 全栈开发启蒙教程 —— 用现代技术栈搭建，同时把教程内容装进项目本身",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "clean": "turbo clean && rm -rf node_modules",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:generate": "bun --filter @app/api db:generate",
    "db:migrate": "bun --filter @app/api db:migrate",
    "db:seed": "bun --filter @app/api db:seed",
    "db:studio": "bun --filter @app/api db:studio",
    "db:reset": "bun run db:down && docker volume rm web-dev-tutorial_pgdata 2>/dev/null || true && bun run db:up && sleep 3 && bun run db:migrate && bun run db:seed"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "bun@1.3.11",
  "engines": {
    "node": ">=20"
  }
}
