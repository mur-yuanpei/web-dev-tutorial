# ---------------------------------------------------------------
# 复制这个文件为 .env，按需修改
# 学生须知：.env 里存的是"环境相关的配置"，比如数据库地址、端口。
# 这些不应该硬编码在代码里，也不应该提交到 git 仓库（.gitignore 已排除）。
# .env.example 是模板，提交到仓库，让每个开发者知道需要哪些变量。
# ---------------------------------------------------------------

# PostgreSQL 连接串。docker-compose.yml 起的库默认就是这个
DATABASE_URL=postgres://dev:dev@localhost:5432/webtutor

# 后端 API 监听端口
API_PORT=3000

# 前端 Vite 开发服务器端口
WEB_PORT=5173

# 前端调用后端的地址（前端专用，必须以 VITE_ 开头才能在浏览器代码里读到）
VITE_API_BASE_URL=http://localhost:3000
